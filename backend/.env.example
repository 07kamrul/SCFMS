# ─────────────────────────────────────────────────────────────
# SCFMS Backend — environment configuration
# Copy to .env and fill real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# App
APP_NAME=SCFMS
ENVIRONMENT=development           # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:3000"]

# Security — GENERATE REAL SECRETS FOR PRODUCTION:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database (PostgreSQL + PostGIS)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=scfms
POSTGRES_PASSWORD=scfms_dev_password
POSTGRES_DB=scfms

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Object storage (MinIO / S3-compatible)
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000
S3_ACCESS_KEY=scfms_minio
S3_SECRET_KEY=scfms_minio_password
S3_BUCKET=scfms-media
S3_REGION=us-east-1

# Login protection
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Geofence defaults (company-overridable later)
DEFAULT_NEAR_DISTANCE_METERS=300
